---
const links = [
  { href: '/itip', label: 'ITIP' },
  { href: '/sie', label: 'SIE' },
  { href: '/standard', label: 'GSM' },
  { href: '/services', label: 'Services' },
];
const external = [
  { href: 'https://docs.poesis.cloud', label: 'Docs' },
  { href: 'https://github.com/poesis-cloud', label: 'GitHub' },
  { href: 'https://www.linkedin.com/company/poesis-cloud', label: 'LinkedIn' },
];
---
<header class="site-header">
  <div class="container nav">
    <a class="brand" href="/">
      <img class="brand-mark" src="/poesis-logo.png" alt="" width="26" height="26" />
      Poesis
    </a>
    <nav class="nav-links" aria-label="Primary">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
      <span class="nav-sep" aria-hidden="true"></span>
      {external.map((l) => <a class="nav-ext" href={l.href} target="_blank" rel="noopener">{l.label}</a>)}
      <a class="btn btn-primary btn-sm" href="/contact">Talk to us</a>
    </nav>
  </div>
</header>

