---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Services"
  description="AI-generative / agentic transformation of your organization, IT first — delivered with the Poesis framework and stack, plus certification for partners and practitioners."
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Transformation</p>
      <h1>AI-native transformation, IT first.</h1>
      <p class="lead">We transform how your organization defines, builds, and governs its systems — using the same open standard, framework, and stack we created. Where it fits, the Poesis stack becomes the governed substrate of the transformation.</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="/contact">Book a conversation</a>
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <div class="grid grid-2">
        <div class="card"><h3>Consulting</h3><p>AI-generative / agentic transformation of organizations, IT first — high-touch, outcome-driven, grounded in systemic governance.</p></div>
        <div class="card"><h3>SaaS</h3><p>The Poesis stack as a managed cloud — durable, recurring, operated by the team that builds it.</p></div>
        <div class="card"><h3>On-prem integration &amp; administration</h3><p>Deploy, integrate, and administer Poesis products inside regulated, sovereign, and enterprise environments.</p></div>
        <div class="card"><h3>Certification</h3><p>A Poesis-owned certification for practitioners and partners — scaling delivery and building the ecosystem.</p></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container center">
      <h2>Bring systemic governance to your organization.</h2>
      <p class="lead" style="margin-inline:auto">Tell us where you are; we'll show you the shortest path to governed, AI-native systems.</p>
      <p><a class="btn btn-primary" href="/contact">Talk to us</a></p>
    </div>
  </section>
</BaseLayout>
