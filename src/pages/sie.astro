---
import BaseLayout from '../layouts/BaseLayout.astro';

const repos = [
  { href: 'https://github.com/poesis-cloud/sie-definition-manager', label: 'sie-definition-manager' },
  { href: 'https://github.com/poesis-cloud/sie-definition-database', label: 'sie-definition-database' },
  { href: 'https://github.com/poesis-cloud/sie-operator', label: 'sie-operator' },
  { href: 'https://github.com/poesis-cloud/sie-definition-blackboard-manager', label: 'sie-definition-blackboard-manager' },
  { href: 'https://github.com/poesis-cloud/sie-definition-blackboard-database', label: 'sie-definition-blackboard-database' },
  { href: 'https://github.com/poesis-cloud/sie-otel-collector', label: 'sie-otel-collector' },
];
---
<BaseLayout
  title="SIE"
  description="SIE — the Systemic Intelligence Engine: the engine that implements and leverages the GSM standard, turning governed definitions into a context AI and agents operate on."
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Engine</p>
      <h1>The Systemic Intelligence Engine.</h1>
      <p class="lead">SIE is the engine that implements and leverages the <a href="/standard">GSM</a> standard — the Definition Manager, Operator, and Blackboard that store governed definitions, enforce their lifecycle, and turn them into a governed AI context that every domain application above it operates on, starting with <a href="/itip">ITIP</a>.</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="https://docs.poesis.cloud/sie-definition/">Read the docs</a>
        <a class="btn btn-ghost" href="https://github.com/poesis-cloud">Browse the repos</a>
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <p class="eyebrow">Why it matters</p>
      <h2>Not just where definitions live — the context AI operates on.</h2>
      <div class="grid grid-2" style="margin-top:1.5rem">
        <div class="card card--feature">
          <h3>A governed AI context.</h3>
          <p>SIE leverages the definitions as a typed, machine-readable context — each one carrying its Archetype's meaning — that applications, humans, and agents can reason and generate from directly. It is the governed account generative models rarely have: what a system <em>is</em>, what it <em>must</em> do, and <em>why</em>.</p>
        </div>
        <div class="card card--feature">
          <h3>Harnessed operations.</h3>
          <p>Operations on that context are harnessed by the definitions themselves: Directives and Norms bound what AI and agentic actions may do, so every operation stays governed, checked, and trustworthy — intuition proposes, the model disposes.</p>
        </div>
      </div>
      <div class="hero-cta" style="margin-top:1.5rem">
        <a class="btn btn-primary" href="https://docs.poesis.cloud/sie-definition/">Read the docs</a>
        <a class="btn btn-ghost" href="/itip">See it run in ITIP</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">What it does</p>
      <h2>Three functional components, one engine.</h2>
      <div class="grid grid-3" style="margin-top:1.5rem">
        <div class="card"><h3>Definition Manager</h3><p>Implements GSM, manages the Ascription lifecycle, and enforces the governance grammar (Directives, Norms, Ascriptions).</p><p style="margin-top:.6rem"><a href="#definition-manager">Explore ↓</a></p></div>
        <div class="card"><h3>Operator</h3><p>The rule runtime that evaluates Norms and Directives against reality — turning definitions into continuous enforcement.</p><p style="margin-top:.6rem"><a href="#operator">Explore ↓</a></p></div>
        <div class="card"><h3>Blackboard</h3><p>Collaborative definition-sourcing with a sealed, byte-stable contribution lifecycle and an append-only audit ledger.</p><p style="margin-top:.6rem"><a href="#blackboard">Explore ↓</a></p></div>
      </div>
    </div>
  </section>

  <section id="definition-manager" class="section section--soft">
    <div class="container">
      <p class="eyebrow">Definition</p>
      <h2>The Definition Manager.</h2>
      <p class="lead">The Definition Manager hosts GSM, manages the Ascription lifecycle (DRAFT → PROPOSED → APPROVED → ACTIVE → DEPRECATED), and enforces the DNA governance grammar across tenant schemas. It is the authoritative store of every governed definition — the heart of the engine.</p>
      <p><a href="https://docs.poesis.cloud/sie-definition/">SIE Definition →</a></p>
    </div>
  </section>

  <section id="operator" class="section">
    <div class="container">
      <p class="eyebrow">Runtime</p>
      <h2>The Operator.</h2>
      <p class="lead">The Operator is the rule runtime: it evaluates Norms and Directives against the observed state, dispatches effectors, and turns governed definitions into continuous enforcement. Definitions stop being documents and become a running control loop — the THINK layer acting on the RUN layer.</p>
      <p><a href="https://docs.poesis.cloud/sie-definition/">SIE Definition →</a></p>
    </div>
  </section>

  <section id="blackboard" class="section section--soft">
    <div class="container">
      <p class="eyebrow">Sourcing</p>
      <h2>The Blackboard.</h2>
      <p class="lead">The Blackboard is a collaborative definition-sourcing service: contributors post evidence-backed contributions, the board is sealed to a byte-stable state, and every mutation is recorded in an append-only audit ledger. It is how raw artifacts become governed definitions, with provenance intact.</p>
      <p><a href="https://docs.poesis.cloud/sie-blackboard/">SIE Blackboard →</a></p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Editor · SaaS · On-prem</p>
      <h2>Adopt it the way your environment demands.</h2>
      <p class="lead">Open-core: a free community edition, a paid enterprise edition, a managed SaaS, or on-prem integration and administration in regulated and sovereign environments — the same engine, three commercial paths.</p>
      <p><a class="btn btn-ghost" href="/services">Talk to us about deployment →</a></p>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <p class="eyebrow">Build with us</p>
      <h2>Documentation &amp; source.</h2>
      <ul class="link-list">
        <li><a href="https://docs.poesis.cloud/sie-definition/">SIE Definition documentation →</a></li>
        <li><a href="https://docs.poesis.cloud/sie-blackboard/">SIE Blackboard documentation →</a></li>
        {repos.map((r) => <li><a href={r.href}>{r.label} →</a></li>)}
      </ul>
      <p style="margin-top:1.5rem" class="muted">Implements the <a href="/standard">GSM</a> standard · powers <a href="/itip">ITIP</a>.</p>
    </div>
  </section>
</BaseLayout>
