---
import BaseLayout from '../layouts/BaseLayout.astro';

const repos = [
  { href: 'https://github.com/poesis-cloud/sie-definition-manager', label: 'sie-definition-manager' },
  { href: 'https://github.com/poesis-cloud/sie-definition-database', label: 'sie-definition-database' },
  { href: 'https://github.com/poesis-cloud/sie-operator', label: 'sie-operator' },
  { href: 'https://github.com/poesis-cloud/sie-definition-blackboard-manager', label: 'sie-definition-blackboard-manager' },
  { href: 'https://github.com/poesis-cloud/sie-definition-blackboard-database', label: 'sie-definition-blackboard-database' },
  { href: 'https://github.com/poesis-cloud/sie-otel-collector', label: 'sie-otel-collector' },
];
---
<BaseLayout
  title="SIE"
  description="SIE — the Systemic Intelligence Engine: the engine that implements and leverages the GSM standard, turning governed definitions into a context AI and agents operate on."
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Engine</p>
      <h1>The Systemic Intelligence Engine.</h1>
      <p class="lead">SIE is the engine that implements and leverages the <a href="/standard">GSM</a> standard — the Definition Manager, Operator, and Blackboard that store governed definitions, enforce their lifecycle, and turn them into a governed AI context that every domain application above it operates on, starting with <a href="/itip">ITIP</a>.</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="https://docs.poesis.cloud/sie-definition/">Read the docs</a>
        <a class="btn btn-ghost" href="https://github.com/poesis-cloud">Browse the repos</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">What it is</p>
      <h2>The runtime home of governed definitions — and the AI context built on them.</h2>
      <div class="grid grid-2" style="margin-top:1.5rem">
        <div class="card"><h3>Definition Manager</h3><p>Implements GSM, manages the Ascription lifecycle, and enforces the governance grammar (Directives, Norms, Ascriptions).</p></div>
        <div class="card"><h3>Operator</h3><p>The rule runtime that evaluates Norms and Directives against reality — turning definitions into continuous enforcement.</p></div>
        <div class="card"><h3>Blackboard</h3><p>A collaborative definition-sourcing service with a sealed, byte-stable contribution lifecycle and an append-only audit ledger.</p></div>
        <div class="card"><h3>A governed AI context</h3><p>SIE leverages the definitions as a typed, machine-readable context — each one carrying its Archetype's meaning — that applications, humans, and agents can reason and generate from directly.</p></div>
        <div class="card"><h3>Harnessed operations</h3><p>Operations on that context are harnessed by the definitions themselves: Directives and Norms bound what AI and agentic actions may do, so every operation stays governed, checked, and trustworthy.</p></div>
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <p class="eyebrow">Editor · SaaS · On-prem</p>
      <h2>Adopt it the way your environment demands.</h2>
      <p class="lead">Open-core: a free community edition, a paid enterprise edition, a managed SaaS, or on-prem integration and administration in regulated and sovereign environments — the same engine, three commercial paths.</p>
      <p><a class="btn btn-ghost" href="/services">Talk to us about deployment →</a></p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Build with us</p>
      <h2>Documentation &amp; source.</h2>
      <ul class="link-list">
        <li><a href="https://docs.poesis.cloud/sie-definition/">SIE Definition documentation →</a></li>
        <li><a href="https://docs.poesis.cloud/sie-blackboard/">SIE Blackboard documentation →</a></li>
        {repos.map((r) => <li><a href={r.href}>{r.label} →</a></li>)}
      </ul>
      <p style="margin-top:1.5rem" class="muted">Implements the <a href="/standard">GSM</a> standard · powers <a href="/itip">ITIP</a>.</p>
    </div>
  </section>
</BaseLayout>
